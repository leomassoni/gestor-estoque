{
  "name": "gestor-estoque",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c yellow,blue \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm --prefix server run dev",
    "postinstall": "npm --prefix server install",
    "build": "tsc -b && vite build",
    "build:client": "tsc -b && vite build",
    "build:server": "npm --prefix server run prisma:generate",
    "render:build": "npm run build && npm run build:server && npm --prefix server run prisma:migrate:deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:push": "npm --prefix server run prisma:push",
    "db:migrate": "npm --prefix server exec prisma migrate dev --schema prisma/schema.prisma",
    "db:studio": "npm --prefix server run prisma:studio",
    "start": "npm run start:server",
    "start:server": "npm --prefix server run start"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-simple-code-editor": "^0.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
