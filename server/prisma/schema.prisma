  @@index([companyId])
  @@index([ownerCompanyId])
  @@index([productId])
}

model AppFlavorProfileRecord {
  id        String   @id
  companyId Int
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}
