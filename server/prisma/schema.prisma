generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

enum ProductMeasurementUnit {
  LITER
  MILLILITER
  KILOGRAM
  GRAM
}

enum ProductMeasurementKind {
  VOLUME
  MASS
}

model Company {
  id             String          @id @default(cuid())
  slug           String          @unique
  legalName      String
  tradeName      String?
  taxId          String?         @unique
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  establishments Establishment[]
  memberships    Membership[]
  products       Product[]
  sectors        Sector[]
  families       ProductFamily[]
  subfamilies    ProductSubfamily[]
  stockMovements StockMovement[]
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
  movements    StockMovement[] @relation("MovementActor")
}

model Membership {
  id         String         @id @default(cuid())
  role       MembershipRole
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  companyId  String
  userId     String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
}

model Establishment {
  id             String           @id @default(cuid())
  companyId      String
  code           String?
  name           String
  city           String?
  state          String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]
  stockMovements StockMovement[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Product {
  id                       String                @id @default(cuid())
  companyId                String
  companyProductId         String?
  name                     String
  description              String?
  barcode                  String?
  measurementKind          ProductMeasurementKind
  measurementUnit          ProductMeasurementUnit
  normalizedUnit           ProductMeasurementUnit
  alcoholPercentage        Decimal?
  densityFactor            Decimal?
  densitySampleVolumeMl    Decimal?
  densitySampleWeightGrams Decimal?
  familyId                 String?
  subfamilyId              String?
  isActive                 Boolean               @default(true)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  company                  Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  family                   ProductFamily?        @relation(fields: [familyId], references: [id], onDelete: SetNull)
  subfamily                ProductSubfamily?     @relation(fields: [subfamilyId], references: [id], onDelete: SetNull)
  sectors                  ProductSector[]
  packages                 ProductPackage[]
  inventoryItems           InventoryItem[]
  stockMovements           StockMovement[]

  @@unique([companyId, companyProductId])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([familyId])
  @@index([subfamilyId])
}

model Sector {
  id          String         @id @default(cuid())
  companyId   String
  name        String
  code        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products    ProductSector[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
}

model ProductFamily {
  id          String             @id @default(cuid())
  companyId   String
  name        String
  code        String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products    Product[]
  subfamilies ProductSubfamily[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
}

model ProductSubfamily {
  id        String          @id @default(cuid())
  companyId String
  familyId  String
  name      String
  code      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  family    ProductFamily   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([familyId, name])
  @@unique([companyId, code])
  @@index([companyId])
  @@index([familyId])
}

model ProductSector {
  id        String    @id @default(cuid())
  productId String
  sectorId  String
  createdAt DateTime  @default(now())
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sector    Sector    @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@unique([productId, sectorId])
  @@index([sectorId])
}

model ProductPackage {
  id                     String                 @id @default(cuid())
  productId              String
  internalCode           String
  label                  String?
  barcode                String?
  packageQuantity        Decimal
  packageUnit            ProductMeasurementUnit
  normalizedQuantity     Decimal
  normalizedUnit         ProductMeasurementUnit
  purchasePrice          Decimal?
  grossWeightGrams       Decimal?
  packagingWeightGrams   Decimal?
  isDefault              Boolean                @default(false)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  product                Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItems         InventoryItem[]
  stockMovements         StockMovement[]

  @@unique([productId, label])
  @@unique([productId, barcode])
  @@unique([productId, internalCode])
  @@index([productId, isDefault])
}

model InventoryItem {
  id              String        @id @default(cuid())
  establishmentId String
  productId       String
  productPackageId String?
  quantity        Decimal       @default(0)
  minQuantity     Decimal?
  openingQuantity Decimal       @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  productPackage  ProductPackage? @relation(fields: [productPackageId], references: [id], onDelete: SetNull)

  @@unique([establishmentId, productId, productPackageId])
  @@index([productId])
  @@index([productPackageId])
}

model StockMovement {
  id                    String            @id @default(cuid())
  type                  StockMovementType
  quantity              Decimal
  reason                String?
  reference             String?
  performedAt           DateTime          @default(now())
  createdAt             DateTime          @default(now())
  companyId             String
  establishmentId       String
  productId             String
  productPackageId      String?
  performedByUserId     String?
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  establishment         Establishment     @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  product               Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productPackage        ProductPackage?   @relation(fields: [productPackageId], references: [id], onDelete: SetNull)
  performedByUser       User?             @relation("MovementActor", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, performedAt])
  @@index([establishmentId, performedAt])
  @@index([productId, performedAt])
  @@index([productPackageId, performedAt])
}

model AppStateSnapshot {
  key       String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppCompanyRecord {
  id           Int      @id
  tradeName    String
  legalName    String
  cnpj         String
  cep          String
  street       String
  number       String
  complement   String
  neighborhood String
  city         String
  state        String
  status       String
  linkedCompanyIds Int[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppAccessProfileRecord {
  id            Int      @id
  companyId     Int
  name          String
  role          String
  sectionAccess Json
  catalogAccess Json
  recipePanelAccess Json
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@unique([companyId, name])
}

model AppUserRecord {
  id             Int      @id
  fullName       String
  username       String   @unique
  password       String
  role           String
  companyId      Int?
  companyIds     Int[]
  sectors        String[]
  sectionAccess  Json
  catalogAccess  Json
  recipePanelAccess Json
  accessProfileId Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  memberships    AppUserCompanyMembershipRecord[]

  @@index([companyId])
  @@index([accessProfileId])
}

model AppUserCompanyMembershipRecord {
  id              Int      @id @default(autoincrement())
  userId          Int
  companyId       Int
  role            String
  sectors         String[]
  sectionAccess   Json
  catalogAccess   Json
  recipePanelAccess Json
  accessProfileId Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            AppUserRecord @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([accessProfileId])
}

model AppStockModuleSettingsRecord {
  companyId                          Int   @id
  inventorySummaryEditProfileIds     Int[]
  inventorySummaryDeleteProfileIds   Int[]
  closedInventoryReopenProfileIds    Int[]
  closedInventoryDeleteProfileIds    Int[]
  salesImportDefaultHistoryMode      String @default("ROLLING_MONTHS")
  salesImportDefaultHistoryMonths    Int    @default(3)
  salesImportDefaultCoverageDays     Int    @default(7)
  salesImportDefaultSafetyMarginPercent String @default("20")
  salesImportAutoApplySuggestedMinimum Boolean @default(true)
  salesImportAllowManualMinimumOverride Boolean @default(true)
  salesImportUnmatchedRowPolicy      String @default("BLOCK")
  salesImportDuplicateRowPolicy      String @default("BLOCK")
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt
}

model AppAuditLogRecord {
  id                Int      @id
  companyId         Int
  actorUserId       Int?
  actorUserName     String
  actorUsername     String
  actorRole         String
  actorKind         String
  module            String
  actionKey         String
  actionLabel       String
  targetType        String
  targetId          String
  targetLabel       String
  summary           String
  impactSummary     String
  severity          String
  result            String
  relatedCompanyIds Int[]
  details           Json
  occurredAt        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AppSalesImportTemplateRecord {
  id             Int      @id
  companyId      Int
  stockCenterId  Int?
  name           String
  sheetName      String
  headerRow      Int
  dataStartRow   Int
  dateMode       String
  dateColumn     String
  dateCell       String
  codeColumn     String
  quantityColumn String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@index([stockCenterId])
}

model AppSalesImportBatchRecord {
  id                  Int      @id
  companyId           Int
  stockCenterId       Int
  templateId          Int?
  uploadedByUserId    Int?
  uploadedByUserName  String
  fileName            String
  historyMode         String
  historyMonths       Int?
  coverageDays        Int
  safetyMarginPercent String
  postingMode         String   @default("ANALYTICAL_ONLY")
  status              String
  importedAt          String
  summary             Json
  createdAtRecord     DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([companyId])
  @@index([stockCenterId])
  @@index([templateId])
  @@index([status])
}

model AppSalesImportRowRecord {
  id                    Int      @id
  batchId               Int
  companyId             Int
  stockCenterId         Int
  sourceRowKey          String
  consumedAt            String
  companyProductId      String
  quantity              String
  matchedTechnicalSheetId Int?
  matchedKind           String
  status                String
  errorMessage          String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([batchId])
  @@index([companyId])
  @@index([stockCenterId])
  @@index([matchedTechnicalSheetId])
  @@index([status])
}

model AppSalesConsumptionRecord {
  id                    Int      @id
  companyId             Int
  stockCenterId         Int
  consumedAt            String
  sourceBatchId         Int
  sourceTechnicalSheetId Int
  sourceTechnicalSheetKind String
  ingredientProductId   String
  quantityConsumed      String
  unit                  String
  stockPostingStatus    String
  stockMovementId       Int?
  postedAt              String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
  @@index([stockCenterId])
  @@index([sourceBatchId])
  @@index([sourceTechnicalSheetId])
  @@index([ingredientProductId])
  @@index([stockPostingStatus])
}

model AppStockCenterRecord {
  id                      Int      @id
  companyId               Int
  name                    String
  code                    String
  sector                  String
  userIds                 Int[]
  responsibleUserIds      Int[]
  isProducer              Boolean  @default(false)
  producedTechnicalSheetIds Int[]
  isDistributor          Boolean  @default(false)
  distributesAllProducts Boolean  @default(false)
  distributedProductIds  String[]
  suppliedCenterIds      Int[]
  minimumStocks           Json
  salesImportSettings    Json
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([companyId])
}

model AppRequisitionRecord {
  id                  Int      @id
  companyId           Int
  requisitionGroupId  Int
  stockCenterId       Int
  stockCenterName     String
  supplyCenterId      Int?
  supplyCenterName    String
  supplyCompanyId     Int?
  supplyCompanyName   String
  sector              String
  countedAt           String
  status              String
  editScope           String
  lines               Json
  createdAt           String
  createdByUserId     Int?
  createdByUserName   String
  approvedAt          String
  approvedByUserId    Int?
  approvedByUserName  String
  sentAt              String
  sentByUserId        Int?
  sentByUserName      String
  preparedAt          String
  preparedByUserId    Int?
  preparedByUserName  String
  receivedAt          String
  receivedByUserId    Int?
  receivedByUserName  String
  lastUpdatedAt       String
  lastUpdatedByUserId Int?
  lastUpdatedByUserName String
  createdAtRecord     DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([companyId])
  @@index([stockCenterId])
  @@index([status])
}

model AppRequisitionNotificationRecord {
  id             Int      @id
  companyId      Int
  userId         Int
  requisitionId  Int
  message        String
  createdAt      String
  isRead         Boolean  @default(false)
  createdAtRecord DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@index([userId])
  @@index([requisitionId])
}

model AppManualProductionRequestRecord {
  id              Int      @id
  companyId       Int
  centerId        Int
  sheetId         Int
  desiredYield    String
  createdAt       String
  createdByUserId Int?
  createdByUserName String
  rootRequestId   Int
  parentRequestId Int?
  isDependencyRequest Boolean @default(false)
  createdAtRecord DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([centerId])
  @@index([sheetId])
  @@index([rootRequestId])
}

model AppProductionDraftRecord {
  draftId                    Int?     @unique
  companyId                  Int
  centerId                   Int
  sheetId                    Int
  startedAt                  String
  startedByUserId            Int?
  startedByUserName          String
  desiredYield               String
  finalYield                 String
  confirmedPh                String
  confirmedBrix              String
  ingredientOverrides        Json
  manualOverrideIngredientIds Int[]
  consumptionSessionId       Int?
  manualRequestIds           Int[]
  createdAtRecord            DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  id                         Int      @id @default(autoincrement())

  @@index([companyId])
  @@index([centerId])
  @@index([sheetId])
}

model AppInventoryStorageLocationRecord {
  companyId Int
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([companyId, name])
  @@index([companyId])
}

model AppInventoryRecord {
  id                          Int      @id
  companyId                   Int
  stockCenterId               Int
  countedAt                   String
  isClosed                    Boolean  @default(false)
  startedAt                   String
  startedByUserId             Int?
  startedByUserName           String
  closedAt                    String
  closedByUserId              Int?
  closedByUserName            String
  discardedOpenSessionCount   Int      @default(0)
  appliedPendingMovementCount Int      @default(0)
  createdAtRecord             DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([companyId])
  @@index([stockCenterId])
}

model AppInventoryActiveRecordLinkRecord {
  companyId Int
  userKey   String
  inventoryId Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([companyId, userKey])
  @@index([companyId])
}

model AppInventoryCountSessionRecord {
  id              Int      @id
  inventoryId     Int?
  companyId       Int
  stockCenterId   Int
  countedAt       String
  isClosed        Boolean  @default(false)
  startedAt       String
  startedByUserId Int?
  startedByUserName String
  closedAt        String
  closedByUserId  Int?
  closedByUserName String
  createdAtRecord DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([inventoryId])
  @@index([stockCenterId])
}

model AppInventoryActiveSessionLinkRecord {
  companyId Int
  userKey   String
  sessionId Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([companyId, userKey])
  @@index([companyId])
}

model AppInventoryCountRecord {
  id                        Int      @id
  inventoryId               Int?
  sessionId                 Int
  companyId                 Int
  stockCenterId             Int
  countedAt                 String
  storageLocation           String
  technicalSheetId          Int?
  productId                 String
  serviceItemId             String
  packageId                 Int?
  technicalSheetName        String
  technicalSheetKind        String
  recipientItemId           String
  recipientLabel            String
  closedItemsQuantity       String
  hasOpenItems              Boolean  @default(false)
  openItemsGrossWeight      String
  openItemsContainerQuantity String
  openItemsNetQuantity      String
  totalCountedQuantity      String
  totalCountedUnit          String
  productionExpectedYield   String
  productionFinalYield      String
  productionYieldDifference String
  productionTargetPh        String
  productionConfirmedPh     String
  productionTargetBrix      String
  productionConfirmedBrix   String
  createdByUserId           Int?
  createdByUserName         String
  createdAtRecord           DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([companyId])
  @@index([inventoryId])
  @@index([sessionId])
  @@index([stockCenterId])
}

model AppPendingInventoryMovementRecord {
  id              Int      @id
  companyId       Int
  stockCenterId   Int
  inventoryId     Int
  createdAt       String
  createdByUserId Int?
  createdByUserName String
  description     String
  session         Json
  records         Json
  createdAtRecord DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([stockCenterId])
  @@index([inventoryId])
}

model AppProductRecord {
  id                  String   @id
