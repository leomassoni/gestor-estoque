  technicalSheetId    Int?
  packages            Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([companyId])
  @@index([ownerCompanyId])
  @@index([technicalSheetId])
}

model AppServiceItemRecord {
